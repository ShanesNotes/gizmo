[gd_resource type="Theme" format=3 uid="uid://ben316v544clg"]

; Brass / gouache HUD theme for Gizmo.
; - Panel: dark translucent fill, beveled brass border (riveted-cartouche feel).
; - ProgressBar: dark recessed track; fills are set per-instance in the scene
;   (cyan for HP, violet for XP) so one theme drives the family.

[sub_resource type="StyleBoxFlat" id="sb_panel"]
bg_color = Color(0.078, 0.067, 0.110, 0.78)
border_width_left = 3
border_width_top = 3
border_width_right = 3
border_width_bottom = 3
border_color = Color(0.776, 0.561, 0.290, 1.0)
corner_radius_top_left = 8
corner_radius_top_right = 8
corner_radius_bottom_right = 8
corner_radius_bottom_left = 8
shadow_color = Color(0.0, 0.0, 0.0, 0.45)
shadow_size = 6

[sub_resource type="StyleBoxFlat" id="sb_panel_inner"]
bg_color = Color(0.043, 0.039, 0.071, 0.65)
border_width_left = 2
border_width_top = 2
border_width_right = 2
border_width_bottom = 2
border_color = Color(0.541, 0.380, 0.184, 1.0)
corner_radius_top_left = 6
corner_radius_top_right = 6
corner_radius_bottom_right = 6
corner_radius_bottom_left = 6

[sub_resource type="StyleBoxFlat" id="sb_bar_bg"]
bg_color = Color(0.039, 0.043, 0.067, 0.90)
border_width_left = 2
border_width_top = 2
border_width_right = 2
border_width_bottom = 2
border_color = Color(0.451, 0.318, 0.157, 1.0)
corner_radius_top_left = 5
corner_radius_top_right = 5
corner_radius_bottom_right = 5
corner_radius_bottom_left = 5

[sub_resource type="StyleBoxFlat" id="sb_bar_fill"]
bg_color = Color(0.196, 0.745, 0.745, 1.0)
corner_radius_top_left = 4
corner_radius_top_right = 4
corner_radius_bottom_right = 4
corner_radius_bottom_left = 4

[resource]
Label/colors/font_color = Color(0.945, 0.886, 0.745, 1.0)
Label/colors/font_outline_color = Color(0.118, 0.082, 0.043, 0.85)
Label/constants/outline_size = 3
PanelContainer/styles/panel = SubResource("sb_panel")
ProgressBar/styles/background = SubResource("sb_bar_bg")
ProgressBar/styles/fill = SubResource("sb_bar_fill")

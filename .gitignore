# --- archives / exports (redundant with design-handoff/) ---
*.zip

# --- FUSE mount artifacts ---
.fuse_hidden*

# --- scratch / preview render folders ---
**/_preview/
**/_prev*/
**/_verify/

# --- dependencies / build caches (for when dev lands here) ---
node_modules/
dist/
.cache/
.vite/
*.log

# --- OS / editor junk ---
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/
*.swp

# --- quarantined pre-art-refactor assets (275MB; preserved locally, not in history) ---
godot/_quarantine/

# --- python tool caches ---
**/__pycache__/
*.py[cod]

# --- concept art binaries: live in the gizmo-design-system repo, not here ---
design-handoff/concept art/

# --- Godot project caches / exports ---
godot/.godot/
godot/export/
godot/exports/

# --- obsidian graph junk (nav hygiene) ---
.obsidian/graph.json
.obsidian/workspace.json
godot/builds/
docs/godot/answer-key/.godot/
*.translation

# --- personal Claude Code settings (not for the published guide) ---
.claude/settings.local.json

# --- temp greybox / staging probe scenes (local only, not shipping; see godot/scenes/_spawn_hearth_greybox.tscn) ---
godot/scenes/_*.tscn

# --- local AI/tool scratch (not source) ---
.scratch/
.claude/
.env
.env.*

# --- generated key-art test iterations (storage path is a user decision; not source) ---
art/generated/

# --- generated soundtrack media (kept local; convert to .ogg for the engine when integrating) ---
godot/audio/gizmo-soundtrack/*.mp4

# --- local temp/scratch (empty cruft dirs; keep clean for agents) ---
tmp/

    "RUST": {"act": 1, "threat": 2, "defacement": 1, "palette": ["rust brown", "oil black", "dim teal", "ember flecks"], "mood": "half-buried titan yard; heavier, more material threats", "landmark_pref": "spire_01"},
    "RUNE": {"act": 2, "threat": 2, "defacement": 1, "optional": "mystery_route", "palette": ["blue-violet stone", "pale rune light", "dark void", "small gold accents"], "mood": "sign and perception; sparse, deliberate placements", "landmark_pref": "orrery_altar_01"},
    "OBS": {"act": 2, "threat": 2, "defacement": 1, "optional": "mystery_route", "palette": ["cyan glass", "silver brass", "indigo sky", "white star flecks"], "mood": "astral observatory; vertical glass-and-brass skyline", "landmark_pref": "spire_01"},
    "PRISM": {"act": 2, "threat": 2, "defacement": 1, "palette": ["violet", "cyan crystal", "dark blue", "small warm gold"], "mood": "refraction; crystal punctuation carries the read", "landmark_pref": "spire_01"},
    "ASH": {"act": 2, "threat": 3, "defacement": 2, "palette": ["ash red", "warm orange", "black iron", "violet core glow"], "mood": "ember foundry; heat without warmth beginning", "landmark_pref": "spire_01"},
    "TEMPEST": {"act": 3, "threat": 3, "defacement": 2, "palette": ["storm blue", "electric teal", "dark violet", "brass rods"], "mood": "tested integration; storm verge, leaning verticals", "landmark_pref": "spire_01"},

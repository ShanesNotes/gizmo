{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/game/**",
              "ui_kits/lumen-codex/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Fredoka|Cormorant Garamond|Nunito))/i]",
        "message": "Font not provided by the design system. Available: Fredoka, Cormorant Garamond, Nunito."
      },
      {
        "selector": "JSXOpeningElement[name.name='BoostButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:state|cooldown|size|onClick|style|key|ref|className|style|children)$/]",
        "message": "<BoostButton> doesn't accept that prop. Declared props: state, cooldown, size, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='BreathRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:total|kept|size|style|key|ref|className|style|children)$/]",
        "message": "<BreathRow> doesn't accept that prop. Declared props: total, kept, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|iconLeft|disabled|full|style|onClick|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, iconLeft, disabled, full, style, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='CovenantRoundel'] > JSXAttribute > JSXIdentifier[name!=/^(?:index|fill|size|showLabel|showMeter|src|style|key|ref|className|style|children)$/]",
        "message": "<CovenantRoundel> doesn't accept that prop. Declared props: index, fill, size, showLabel, showMeter, src, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|color|size|style|key|ref|className|style|children)$/]",
        "message": "<Eyebrow> doesn't accept that prop. Declared props: children, color, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Joystick'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|knobSize|variant|dx|dy|interactive|onMove|style|key|ref|className|style|children)$/]",
        "message": "<Joystick> doesn't accept that prop. Declared props: size, knobSize, variant, dx, dy, interactive, onMove, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Joystick'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:fixed|floating)$/]",
        "message": "<Joystick> variant must be one of 'fixed' | 'floating'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Keycap'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|size|style|key|ref|className|style|children)$/]",
        "message": "<Keycap> doesn't accept that prop. Declared props: children, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Meter'] > JSXAttribute > JSXIdentifier[name!=/^(?:fill|hue|xp|height|track|style|key|ref|className|style|children)$/]",
        "message": "<Meter> doesn't accept that prop. Declared props: fill, hue, xp, height, track, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Panel'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|eyebrow|tone|dashed|style|key|ref|className|style|children)$/]",
        "message": "<Panel> doesn't accept that prop. Declared props: children, eyebrow, tone, dashed, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Pill'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|dot|count|sealed|style|key|ref|className|style|children)$/]",
        "message": "<Pill> doesn't accept that prop. Declared props: children, dot, count, sealed, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Seal'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|glow|children|style|key|ref|className|style|children)$/]",
        "message": "<Seal> doesn't accept that prop. Declared props: size, glow, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatCell'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|hue|style|key|ref|className|style|children)$/]",
        "message": "<StatCell> doesn't accept that prop. Declared props: label, value, hue, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TouchControls'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|small|boostState|cooldown|onMove|onBoost|gutter|absolute|Joystick|BoostButton|style|key|ref|className|style|children)$/]",
        "message": "<TouchControls> doesn't accept that prop. Declared props: variant, small, boostState, cooldown, onMove, onBoost, gutter, absolute, Joystick, BoostButton, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TouchControls'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:fixed|floating)$/]",
        "message": "<TouchControls> variant must be one of 'fixed' | 'floating'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TouchControls'] > JSXAttribute[name.name='boostState'] > Literal[value!=/^(?:default|snap-window|queued|scooping|cooling|disabled)$/]",
        "message": "<TouchControls> boostState must be one of 'default' | 'snap-window' | 'queued' | 'scooping' | 'cooling' | 'disabled'."
      },
      {
        "selector": "JSXOpeningElement[name.name='UpgradeCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:rarity|name|desc|pill|statLabel|statValue|hotkey|iconIndex|iconSrc|lifted|width|style|key|ref|className|style|children)$/]",
        "message": "<UpgradeCard> doesn't accept that prop. Declared props: rarity, name, desc, pill, statLabel, statValue, hotkey, iconIndex, iconSrc, lifted, width, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='VerdictBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|desc|count|total|fill|icon|compact|width|style|key|ref|className|style|children)$/]",
        "message": "<VerdictBar> doesn't accept that prop. Declared props: title, desc, count, total, fill, icon, compact, width, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
